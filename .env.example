# ─── Core ───────────────────────────────────────────────
SERVICE_NAME=aipr
# Set RUN_OFFLINE=true to run without OpenAI/Redis/Postgres (uses StubLLM + sqlite in-memory).
# For real deployment set RUN_OFFLINE=false.
RUN_OFFLINE=true
LOG_LEVEL=INFO

# ─── Core ───────────────────────────────────────────────
SERVICE_NAME=aipr
# Set RUN_OFFLINE=true to run without any LLM/Redis/Postgres (uses StubLLM + sqlite).
# For real deployment set RUN_OFFLINE=false.
RUN_OFFLINE=true
LOG_LEVEL=INFO

# ─── LLM (provider-agnostic) ───────────────────────────
# LLM_PROVIDER: "openai-compatible" (default) OR "anthropic".
#   - openai-compatible works with OpenAI AND any OpenAI-compatible API:
#     OpenRouter, Groq, DeepSeek, Together, Ollama, vLLM, Azure OpenAI.
#   - anthropic uses Claude natively (claude-3-5-sonnet-latest, etc).
LLM_PROVIDER=openai-compatible
# API key for the chosen provider. Ollama / local vLLM often need no key (leave blank).
LLM_API_KEY=sk-...
# Model name recognised by the provider (gpt-4o-mini, claude-3-5-sonnet-latest,
# deepseek/deepseek-chat, llama3.1, ...).
LLM_MODEL=gpt-4o-mini
# Base URL of the API. Default = OpenAI. Examples:
#   OpenRouter  -> https://openrouter.ai/api/v1
#   Groq        -> https://api.groq.com/openai/v1
#   DeepSeek    -> https://api.deepseek.com/v1
#   Ollama      -> http://localhost:11434/v1
#   vLLM        -> http://localhost:8000/v1
LLM_BASE_URL=https://api.openai.com/v1

# Legacy aliases (still honoured if the LLM_* vars above are unset):
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ─── GitHub ─────────────────────────────────────────────
GITHUB_API_URL=https://api.github.com
# Shared secret configured in the GitHub webhook (HMAC-SHA256 verification).
GITHUB_WEBHOOK_SECRET=change-me-to-a-long-random-string
# Optional PAT used for diff fetching / posting when not using a GitHub App.
GITHUB_TOKEN=
# GitHub App credentials (used for JWT + installation token posting).
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_PATH=

# ─── Persistence ───────────────────────────────────────
# Async SQLAlchemy URL. sqlite+aiosqlite for offline; postgresql+asyncpg://... for prod.
DATABASE_URL=sqlite+aiosqlite:///./aipr.db

# ─── Queue ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── Service discovery (internal) ──────────────────────
GATEWAY_URL=http://localhost:8000
WEBHOOK_URL=http://localhost:8001
ORCHESTRATOR_URL=http://localhost:8002
REVIEWER_URL=http://localhost:8003
LEARNER_URL=http://localhost:8004

# ─── Tuning ────────────────────────────────────────────
REVIEWER_MAX_COMMENTS=30

# ─── Observability (optional) ──────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
